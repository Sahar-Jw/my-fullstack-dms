{
  "compilerOptions": {
    "target": "ES2017",
    "lib": [
      "dom",
      "dom.iterable",
      "esnext"
    ],
    "allowJs": true,
    "skipLibCheck": true,
    "strict": false,
    "noEmit": true,
    "incremental": true,
    "module": "esnext",
    "esModuleInterop": true,
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "jsx": "react-jsx",
    "plugins": [
      {
        "name": "next"
      }
    ]
  },
  "include": [
    "next-env.d.ts",
    ".next/types/**/*.ts",
    ".next/dev/types/**/*.ts",
    "**/*.mts",
    "**/*.ts",
    "**/*.tsx"
, "src/app/login/page.jsx", "src/app/layout.jsx", "src/app/page.jsx", "src/context/AppContext.jsx", "src/components/icons.jsx", "src/components/ui/Toast.jsx", "src/components/ui/Stamp.jsx", "src/components/ui/Modal.jsx", "src/components/ui/Badge.jsx", "src/components/modals/UserModal.jsx", "src/components/modals/DepartmentModal.jsx", "src/components/modals/ConfirmModal.jsx", "src/components/modals/CategoryModal.jsx", "src/components/modals/AttachmentModal.jsx", "src/components/layout/Topbar.jsx", "src/components/layout/Sidebar.jsx", "src/components/documents/DocumentForm.jsx", "src/app/(app)/layout.jsx", "src/app/(app)/users/page.jsx", "src/app/(app)/settings/page.jsx", "src/app/(app)/search/page.jsx", "src/app/(app)/documents/new/page.jsx", "src/app/(app)/documents/page.jsx", "src/app/(app)/documents/[id]/page.jsx", "src/app/(app)/documents/[id]/edit/page.jsx", "src/app/(app)/departments/page.jsx", "src/app/(app)/dashboard/page.jsx", "src/app/(app)/categories/page.jsx"  ],
  "exclude": [
    "node_modules"
  ]
}
